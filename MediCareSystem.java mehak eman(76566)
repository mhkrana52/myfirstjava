// Abstract Class: Abstraction + Encapsulation - Requirement
abstract class Person implements Serializable {
    private static final long serialVersionUID = 1L;
    protected String name;
    public abstract String getDetails();
    public String getName() { return name; }
    public void setName(String name) { this.name = name; }
}

// Concrete Class: Inheritance + Polymorphism + Encapsulation - Requirement
class Patient extends Person {
    private String id, disease, doctor, bill;

    public Patient(String id, String name, String disease, String doctor, String bill) {
        this.setName(name);
        this.id = id; this.disease = disease;
        this.doctor = doctor; this.bill = bill;
    }

    @Override // Polymorphism
    public String getDetails() { return "ID: " + id + " - Name: " + getName(); }

    public String getId() { return id; }
    public String getDisease() { return disease; }
    public String getDoctor() { return doctor; }
    public String getBill() { return bill; }
}

