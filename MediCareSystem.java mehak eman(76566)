    // Interface 1 Implementation
    @Override
    public boolean login(String user, String pass) {
        return user.equals("admin") && pass.equals("1234");
    }

    @Override
    public void register(String user, String pass) {
        JOptionPane.showMessageDialog(this, "Registered! Use admin/1234 to login");
    }

    // Interface 2 Implementation
    @Override
    public void addPatient() {
        if(idField.getText().trim().isEmpty() || nameField.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "ID and Name required!");
            return;
        }
        patientModel.addRow(new Object[]{idField.getText(), nameField.getText(),
                diseaseField.getText(), doctorField.getText(), billField.getText()});
        clearFields();
    }

    @Override
    public void dischargePatient() {
        int row = patientTable.getSelectedRow();
        if(row >= 0) {
            selectedPatientId = patientModel.getValueAt(row, 0).toString();
            showCheckout();
        } else JOptionPane.showMessageDialog(this, "Select patient to discharge!");
    }

    @Override
    public void searchPatient(String id) {
        for(int i = 0; i < patientModel.getRowCount(); i++) {
            if(patientModel.getValueAt(i, 0).toString().equals(id)) {
                patientTable.setRowSelectionInterval(i, i);
                JOptionPane.showMessageDialog(this, "Patient Found!");
                return;
            }
        }
        JOptionPane.showMessageDialog(this, "Not Found!");
    }

    @Override
    public void showMedicines() {
        cardLayout.show(mainPanel, "MEDICINES");
    }

    @Override
    public void showCheckout() {
        cardLayout.show(mainPanel, "CHECKOUT");
    }

    // Interface 3 Implementation - File Handling + Cart - Requirement
    @Override
    public void addToCart() {
        int row = medicineTable.getSelectedRow();
        if(row >= 0) {
            String med = medicineModel.getValueAt(row, 0).toString();
            double price = Double.parseDouble(medicineModel.getValueAt(row, 1).toString());
            int qty = 1;
            double total = price * qty;
            cartModel.addRow(new Object[]{med, price, qty, total});
            updateCartTotal();
            JOptionPane.showMessageDialog(this, "Added to Cart!");
        } else {
            JOptionPane.showMessageDialog(this, "Select medicine first!");
        }
    }

    @Override
    public void removeFromCart() {
        int row = cartTable.getSelectedRow();
        if(row >= 0) {
            cartModel.removeRow(row);
            updateCartTotal();
        }
    }

    @Override
    public void clearCart() {
        cartModel.setRowCount(0);
        updateCartTotal();
    }

    @Override
    public void saveData() {
        try(ObjectOutputStream out = new ObjectOutputStream(new FileOutputStream("patients.dat"))) {
            for(int i = 0; i < patientModel.getRowCount(); i++) {
                Patient p = new Patient(patientModel.getValueAt(i,0).toString(), patientModel.getValueAt(i,1).toString(),
                        patientModel.getValueAt(i,2).toString(), patientModel.getValueAt(i,3).toString(), patientModel.getValueAt(i,4).toString());
                out.writeObject(p);
            }
            JOptionPane.showMessageDialog(this, "Data Saved Successfully!");
        } catch(Exception ex) { ex.printStackTrace(); }
    }

    @Override
    public void loadData() {
        File file = new File("patients.dat");
        if(!file.exists()) return;
        try(ObjectInputStream in = new ObjectInputStream(new FileInputStream(file))) {
            patientModel.setRowCount(0);
            while(true) {
                Patient p = (Patient) in.readObject();
                patientModel.addRow(new Object[]{p.getId(), p.getName(), p.getDisease(), p.getDoctor(), p.getBill()});
            }
        } catch(EOFException ex) {
            JOptionPane.showMessageDialog(this, "Data Loaded Successfully!");
        } catch(Exception ex) { ex.printStackTrace(); }
    }

    @Override
    public void generateSlip() {
        if(selectedPatientId.isEmpty()) {
            JOptionPane.showMessageDialog(this, "No patient selected!");
            return;
        }
        
        for(int i = 0; i < patientModel.getRowCount(); i++) {
            if(patientModel.getValueAt(i, 0).toString().equals(selectedPatientId)) {
                String slip = "=================================\n";
                slip += " MEDICARE HOSPITAL\n";
                slip += " DISCHARGE SLIP\n";
                slip += "=================================\n";
                slip += "Date: " + new SimpleDateFormat("dd-MM-yyyy HH:mm").format(new Date()) + "\n\n";
                slip += "Patient ID: " + patientModel.getValueAt(i, 0) + "\n";
                slip += "Name: " + patientModel.getValueAt(i, 1) + "\n";
                slip += "Disease: " + patientModel.getValueAt(i, 2) + "\n";
                slip += "Doctor: " + patientModel.getValueAt(i, 3) + "\n";
                slip += "---------------------------------\n";
                slip += "Treatment Bill: Rs. " + patientModel.getValueAt(i, 4) + "\n";
                slip += "Medicine Bill: Rs. " + getCartTotal() + "\n";
                slip += "---------------------------------\n";
                slip += "Grand Total: Rs. " + (Double.parseDouble(patientModel.getValueAt(i, 4).toString()) + getCartTotal()) + "\n\n";
                slip += "Customer Details:\n";
                slip += "Name: " + checkoutName.getText() + "\n";
                slip += "Email: " + checkoutEmail.getText() + "\n";
                slip += "Contact: " + checkoutContact.getText() + "\n";
                slip += "Address: " + checkoutAddress.getText() + "\n";
                slip += "=================================\n";
                slip += " Thank You! Get Well Soon\n";
                slip += "=================================";
                
                slipArea.setText(slip);
                cardLayout.show(mainPanel, "SLIP");
                
                // Discharge patient after slip
                patientModel.removeRow(i);
                clearCart();
                selectedPatientId = "";
                return;
            }
        }
    }

    private void updateCartTotal() {
        double total = 0;
        for(int i = 0; i < cartModel.getRowCount(); i++) {
            total += Double.parseDouble(cartModel.getValueAt(i, 3).toString());
        }
        cartTotalLabel.setText("Total: " + total);
    }

    private double getCartTotal() {
        double total = 0;
        for(int i = 0; i < cartModel.getRowCount(); i++) {
            total += Double.parseDouble(cartModel.getValueAt(i, 3).toString());
        }
        return total;
    }

    private void clearFields() {
        idField.setText(""); nameField.setText(""); diseaseField.setText("");
        doctorField.setText(""); billField.setText("");
    }

